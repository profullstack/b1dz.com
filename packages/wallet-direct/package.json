{
  "name": "@b1dz/wallet-direct",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./evm": {
      "import": "./src/evm.ts",
      "default": "./src/evm.ts"
    },

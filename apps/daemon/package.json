{
  "name": "@b1dz/daemon",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "bin": {
    "b1dzd": "./bin/b1dzd"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@b1dz/core": "workspace:*",
    "@b1dz/storage-supabase": "workspace:*",
    "@b1dz/source-dealdash": "workspace:*",
    "@supabase/supabase-js": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

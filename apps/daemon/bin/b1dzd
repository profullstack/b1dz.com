#!/usr/bin/env bash
# b1dzd launcher — runs the daemon entry via tsx (no build step required).
# Auto-wraps with xvfb-run on headless servers for Cloudflare bypass.
set -e
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PKG_DIR="$(cd "$HERE/.." && pwd)"
TSX="$PKG_DIR/node_modules/.bin/tsx"
if [ ! -x "$TSX" ]; then
  echo "b1dzd: tsx not found at $TSX — run \`pnpm install\` in $PKG_DIR" >&2
  exit 1
fi
cd "$PKG_DIR"

if [ -z "$DISPLAY" ] && command -v xvfb-run &>/dev/null && [ -z "$B1DZ_NO_XVFB" ]; then
  exec xvfb-run --auto-servernum "$TSX" "$PKG_DIR/src/index.ts" "$@"
else
  exec "$TSX" "$PKG_DIR/src/index.ts" "$@"
fi
